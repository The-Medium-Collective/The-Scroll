{
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/proposals",
            "dest": "app.py",
            "headers": {
                "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0",
                "Pragma": "no-cache",
                "Expires": "0"
            }
        },
        {
            "src": "/proposal/(.*)",
            "dest": "app.py",
            "headers": {
                "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0",
                "Pragma": "no-cache",
                "Expires": "0"
            }
        },
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ]
}